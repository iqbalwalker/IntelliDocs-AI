SECRET_KEY=replace_me_later

DEBUG=True

ALLOWED_HOSTS=127.0.0.1,localhost #or you can use your domain name if you have one

GEMINI_API_KEY=your_gemini_api_key_here  /*you can use other LLMs given that you install the required
                                                dependencies for the specific LLM you want to use. 
                                                For example, if you want to use OpenAI's GPT-3, 
                                                you would need to install the openai package 
                                                and set your OPEN AI_API_KEY here.*/

DATABASE_URL=url_to_your_database_here   /*For example, if you are using PostgreSQL, 
                                             your DATABASE_URL might look like this: 
                                             postgres://user:password@localhost:5432/mydatabase. 
                                             Make sure to replace user, password, localhost, 
                                             and mydatabase with your actual database credentials.*/